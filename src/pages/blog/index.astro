---
import { getCollection } from 'astro:content';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import TagPills from '../../components/TagPills.astro';
import { SITE_DESCRIPTION, SITE_TITLE, SITE_URL } from '../../consts';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getPublishedPosts } from '../../utils/blog';

const posts = getPublishedPosts(await getCollection('blog'));
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Blog',
	name: `${SITE_TITLE} Blog`,
	description: SITE_DESCRIPTION,
	url: `${SITE_URL}/blog/`,
};
---

<Layout
	title={`Blog | ${SITE_TITLE}`}
	description="Astro blog posts, technical notes, and product engineering writing."
	keywords={['Astro blog', 'technical notes', 'frontend systems', 'developer writing']}
	structuredData={structuredData}
>
	<div class="page-shell">
		<SiteHeader active="blog" />

		<main class="blog-page">
			<section class="blog-hero panel">
				<p class="eyebrow">Astro blog</p>
				<h1>文章內容走 content collections，頁面走靜態產生。</h1>
				<p class="lead">
					這個 blog 架構把內容、路由、版型分開管理。之後新增文章只要在
					<code>src/content/blog/</code> 放一篇 Markdown。
				</p>
				<div class="blog-hero__links">
					<a href="/blog/tags">Browse tags</a>
					<a href="/rss.xml">Subscribe via RSS</a>
				</div>
			</section>

			<section class="blog-list">
				<div class="section-heading">
					<p class="section-heading__eyebrow">All posts</p>
					<h2>目前文章列表</h2>
				</div>

				<div class="post-grid">
					{
						posts.map((post) => (
							<article class="post-card panel">
								<p class="post-card__meta">
									<span>{formatDate(post.data.pubDate)}</span>
									<span>{post.data.tags.length} tags</span>
								</p>
								<h3>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</h3>
								<p>{post.data.description}</p>
								<TagPills tags={post.data.tags} />
							</article>
						))
					}
				</div>
			</section>
		</main>

		<SiteFooter />
	</div>
</Layout>

<style>
	.page-shell {
		width: var(--content-width);
		margin: 0 auto;
		padding: 1rem 0 4rem;
	}

	.blog-page {
		display: grid;
		gap: 2rem;
	}

	.panel {
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(245, 249, 246, 0.92)),
			var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow);
		backdrop-filter: blur(20px);
	}

	.blog-hero,
	.post-card {
		padding: clamp(1.25rem, 2vw, 1.75rem);
	}

	.eyebrow,
	.section-heading__eyebrow,
	.post-card__meta {
		margin: 0 0 0.9rem;
		font-family: var(--font-mono);
		font-size: 0.76rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-strong);
	}

	h1,
	h2,
	h3,
	p {
		margin: 0;
	}

	h1,
	h2,
	h3 {
		color: var(--heading);
	}

	h1 {
		font-size: clamp(2.5rem, 7vw, 4.75rem);
		line-height: 0.96;
		letter-spacing: -0.06em;
		max-width: 13ch;
	}

	h2 {
		font-size: clamp(1.8rem, 4vw, 2.6rem);
		line-height: 1;
		letter-spacing: -0.05em;
	}

	h3 {
		font-size: 1.35rem;
		line-height: 1.2;
		letter-spacing: -0.04em;
	}

	code {
		padding: 0.1rem 0.45rem;
		border-radius: 999px;
		background: var(--accent-soft);
		font-family: var(--font-mono);
		font-size: 0.88em;
	}

	.lead,
	.post-card p {
		font-size: 1rem;
		line-height: 1.75;
		color: var(--text-muted);
	}

	.lead {
		margin-top: 1rem;
		max-width: 42rem;
	}

	.blog-hero__links {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1.25rem;
	}

	.blog-hero__links a {
		color: var(--accent-strong);
		text-decoration: none;
	}

	.blog-hero__links a:hover {
		text-decoration: underline;
	}

	.blog-list,
	.section-heading {
		display: grid;
		gap: 1.25rem;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.post-card {
		display: grid;
		gap: 0.9rem;
	}

	.post-card__meta {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
	}

	.post-card a {
		text-decoration: none;
	}

	.post-card a:hover {
		color: var(--accent-strong);
	}

	@media (max-width: 1100px) {
		.post-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 720px) {
		.page-shell {
			padding-bottom: 3rem;
		}

		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
