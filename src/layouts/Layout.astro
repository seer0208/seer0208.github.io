---
import {
	DEFAULT_OG_IMAGE,
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_TITLE,
	SITE_URL,
} from '../consts';

interface Props {
	title?: string;
	description?: string;
	type?: 'website' | 'article';
	ogImage?: string;
	ogImageAlt?: string;
	keywords?: string[];
	noindex?: boolean;
	publishedTime?: Date | string;
	modifiedTime?: Date | string;
	structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	type = 'website',
	ogImage = DEFAULT_OG_IMAGE,
	ogImageAlt = `${SITE_TITLE} Open Graph image`,
	keywords = [],
	noindex = false,
	publishedTime,
	modifiedTime,
	structuredData,
} = Astro.props as Props;

const baseUrl = Astro.site ?? new URL(SITE_URL);
const canonical = new URL(Astro.url.pathname, baseUrl).toString();
const resolvedOgImage = new URL(ogImage, baseUrl).toString();
const robots = noindex ? 'noindex,nofollow' : 'index,follow';
const keywordContent = keywords.length > 0 ? keywords.join(', ') : undefined;
const isoPublishedTime = publishedTime ? new Date(publishedTime).toISOString() : undefined;
const isoModifiedTime = modifiedTime ? new Date(modifiedTime).toISOString() : undefined;
const structuredDataItems = structuredData
	? Array.isArray(structuredData)
		? structuredData
		: [structuredData]
	: [];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={canonical} />
		<link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS Feed`} href="/rss.xml" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="author" content={SITE_AUTHOR} />
		<meta name="description" content={description} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content="#eef3ee" />
		<meta name="color-scheme" content="light" />
		{keywordContent && <meta name="keywords" content={keywordContent} />}
		<meta property="og:locale" content="zh_TW" />
		<meta property="og:type" content={type} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content={SITE_TITLE} />
		<meta property="og:image" content={resolvedOgImage} />
		<meta property="og:image:alt" content={ogImageAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedOgImage} />
		{isoPublishedTime && <meta property="article:published_time" content={isoPublishedTime} />}
		{isoModifiedTime && <meta property="article:modified_time" content={isoModifiedTime} />}
		<title>{title}</title>
		{
			structuredDataItems.map((item) => (
				<script type="application/ld+json" set:html={JSON.stringify(item)} />
			))
		}
	</head>
	<body>
		<div class="site-background" aria-hidden="true">
			<div class="site-background__glow site-background__glow--one"></div>
			<div class="site-background__glow site-background__glow--two"></div>
			<div class="site-background__grid"></div>
		</div>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
		--page-bg: #eef3ee;
		--page-bg-alt: #f8fbf8;
		--surface: rgba(248, 251, 248, 0.82);
		--surface-strong: rgba(255, 255, 255, 0.92);
		--surface-muted: rgba(235, 241, 236, 0.8);
		--border: rgba(15, 23, 42, 0.1);
		--border-strong: rgba(15, 23, 42, 0.18);
		--text: #102418;
		--text-muted: #496055;
		--heading: #08150d;
		--accent: #0e7490;
		--accent-soft: rgba(14, 116, 144, 0.12);
		--accent-strong: #155e75;
		--shadow: 0 24px 80px rgba(33, 61, 43, 0.12);
		--radius-xl: 32px;
		--radius-lg: 24px;
		--radius-md: 18px;
		--radius-sm: 12px;
		--content-width: min(1120px, calc(100vw - 2rem));
		--font-display:
			'Space Grotesk', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', sans-serif;
		--font-body:
			'Space Grotesk', 'Avenir Next', 'Segoe UI', 'Helvetica Neue', sans-serif;
		--font-mono:
			'IBM Plex Mono', 'SFMono-Regular', 'Cascadia Code', 'Source Code Pro', monospace;
	}

	* {
		box-sizing: border-box;
	}

	html {
		margin: 0;
		min-height: 100%;
		background:
			radial-gradient(circle at top left, rgba(14, 116, 144, 0.12), transparent 30%),
			linear-gradient(180deg, var(--page-bg-alt) 0%, var(--page-bg) 100%);
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-height: 100vh;
		color: var(--text);
		font-family: var(--font-body);
		text-rendering: optimizeLegibility;
		position: relative;
	}

	a {
		color: inherit;
	}

	button,
	input,
	textarea,
	select {
		font: inherit;
	}

	::selection {
		background: rgba(14, 116, 144, 0.18);
	}

	.site-background {
		position: fixed;
		inset: 0;
		pointer-events: none;
		overflow: clip;
		z-index: -1;
	}

	.site-background__glow {
		position: absolute;
		border-radius: 999px;
		filter: blur(80px);
		opacity: 0.75;
	}

	.site-background__glow--one {
		top: -8rem;
		right: -6rem;
		width: 28rem;
		height: 28rem;
		background: rgba(56, 189, 248, 0.2);
	}

	.site-background__glow--two {
		left: -10rem;
		top: 24rem;
		width: 24rem;
		height: 24rem;
		background: rgba(34, 197, 94, 0.12);
	}

	.site-background__grid {
		position: absolute;
		inset: 0;
		background-image:
			linear-gradient(rgba(16, 36, 24, 0.06) 1px, transparent 1px),
			linear-gradient(90deg, rgba(16, 36, 24, 0.06) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.65), transparent 85%);
	}
</style>
